# ==============================================
# БАЗА ДАННЫХ MYSQL
# ==============================================
# Хост MySQL базы данных
MYSQL_HOST=mysql80.hostland.ru
# Имя пользователя MySQL
MYSQL_USERNAME=host1708875_redparty
# Пароль пользователя MySQL
MYSQL_PASSWORD=password123
# Название базы данных
MYSQL_DATABASE=host1708875_leaderboarddev
# Порт MySQL (стандартный: 3306)
MYSQL_PORT=3306

# ==============================================
# НАСТРОЙКИ СБОРА ДАННЫХ
# ==============================================

# Активные лимиты турниров для сбора (через запятую)
# Пример: 16-25 = турниры от 16€ до 25€
ACTIVE_LIMITS=16-25,50,100

# Минимальное количество очков для сохранения игрока
# 0 = сохранять всех игроков, >0 = фильтровать по очкам
MIN_POINTS_FILTER=0

# Проверка дубликатов перед сохранением (true/false)
# true = не сохранять одинаковые записи за один день по миланскому времени
CHECK_DUPLICATES=true

# Интервал сбора данных в минутах
# По умолчанию: 6 минут между запусками
SCRAPING_INTERVAL_MINUTES=6

# ==============================================
# ЧАСОВОЙ ПОЯС И ВРЕМЯ
# ==============================================

# Часовой пояс для расчетов (Милан, Италия)
# Важно: в полночь по этому времени у игроков сбрасываются очки
TIMEZONE=Europe/Rome

# Учитывать сброс очков в полночь (true/false)
# true = предотвращает отрицательные значения при переходе через полночь
HANDLE_MIDNIGHT_RESET=true

# ==============================================
# НАСТРОЙКИ СЕРВЕРА
# ==============================================

# Порт для веб-интерфейса и API
PORT=3000

# Уровень логирования (error, warn, info, debug)
LOG_LEVEL=info

# ==============================================
# НАСТРОЙКИ СКРАПИНГА
# ==============================================

# Таймаут ожидания загрузки страницы (миллисекунды)
SCRAPING_TIMEOUT=30000

# Задержка между запросами к разным лимитам (миллисекунды)
# Помогает избежать блокировки от сайта
SCRAPING_DELAY=2000

# Предотвращение параллельных запусков (true/false)
# true = использовать систему блокировки через lockfile
PREVENT_PARALLEL_RUNS=true

# ==============================================
# НАСТРОЙКИ TELEGRAM УВЕДОМЛЕНИЙ
# ==============================================

# Токен Telegram бота для отправки уведомлений
BOT_TOKEN=7967034123123123123123123Bmb-muE

# ID чата для отправки уведомлений
# Можно получить через @userinfobot в Telegram
CHAT_ID=28123885
